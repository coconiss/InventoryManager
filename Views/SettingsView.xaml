<UserControl x:Class="InventoryManager.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Margin="24" VerticalScrollBarVisibility="Auto">
        <StackPanel>

            <!-- ── 바코드 스캐너 설정 ─────────────────────────────── -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="📡 바코드 스캐너" Style="{StaticResource SectionTitle}"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="연결 방식"
                                   Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1" Margin="0,0,8,0"
                                  SelectedItem="{Binding ScannerMode}" HorizontalContentAlignment="Left">
                            <ComboBoxItem>USB (HID) - 자동</ComboBoxItem>
                            <ComboBoxItem>Serial (COM)</ComboBoxItem>
                            <ComboBoxItem>Bluetooth</ComboBoxItem>
                        </ComboBox>
                        <Button Grid.Column="2" Content="연결 테스트"
                                Style="{StaticResource GhostButton}"
                                Command="{Binding TestScannerCommand}"/>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="COM 포트"
                                   Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1" Margin="0,0,12,0"
                                  ItemsSource="{Binding AvailablePorts}"
                                  SelectedItem="{Binding SelectedPort}"/>
                        <TextBlock Grid.Column="2" Text="통신속도(Baud)"
                                   Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="3"
                                 Text="{Binding BaudRate, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>

                    <TextBlock Margin="0,8,0,0"
                               Text="{Binding StatusMessage}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Border>

            <!-- ── 재고 경고 설정 ─────────────────────────────────── -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="⚠️ 재고 경고" Style="{StaticResource SectionTitle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="경고 기준 수량 (전체 공통)"
                                   VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Margin="12,0"
                                 Text="{Binding LowStockWarning, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Text="개 이하이면 노란색으로 표시"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ── 백업 설정 ──────────────────────────────────────── -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="💾 데이터 백업" Style="{StaticResource SectionTitle}"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Margin="0,0,8,0"
                                 Text="{Binding BackupPath}"
                                 IsReadOnly="True"/>
                        <Button Grid.Column="1" Content="폴더 선택"
                                Style="{StaticResource GhostButton}"
                                Command="{Binding SelectBackupFolderCommand}"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal">
                        <CheckBox Content="자동 백업 (24시간 주기)"
                                  IsChecked="{Binding AutoBackup}"
                                  VerticalAlignment="Center" Margin="0,0,20,0"/>
                        <Button Content="지금 백업"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding BackupNowCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ── 라이선스 ──────────────────────────────────────── -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="📄 라이선스" Style="{StaticResource SectionTitle}"/>
                    <Border Background="{StaticResource ContentBgBrush}"
                            CornerRadius="6" Padding="16">
                        <TextBlock Text="{Binding LicenseText}"
                                   FontFamily="Consolas" FontSize="12"
                                   TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Border>

            <Button Content="💾 설정 저장"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding SaveSettingsCommand}"
                    HorizontalAlignment="Right"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>