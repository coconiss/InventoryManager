<UserControl x:Class="InventoryManager.Views.RevenueView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ 조회 조건 카드 ════════════════════════════════════════ -->
        <Border Grid.Row="0" Style="{StaticResource Card}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="기간:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <DatePicker SelectedDate="{Binding FromDate}" Width="130" Margin="0,0,8,0"/>
                <TextBlock Text="~" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <DatePicker SelectedDate="{Binding ToDate}" Width="130" Margin="0,0,16,0"/>
                <Button Content="🔎 조회"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding LoadCommand}"
                        Margin="0,0,8,0"/>
                <Border Background="{StaticResource ContentBgBrush}"
                        CornerRadius="6" Padding="16,6" Margin="20,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="총 매출: " Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock FontWeight="Bold" Foreground="{StaticResource AccentBrush}">
                            <TextBlock.Text>
                                <Binding Path="TotalRevenue" StringFormat="{}{0:N0} 원"/>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- ═══ 탭 (일별 / 월별 / 제품별) ═══════════════════════════ -->
        <TabControl Grid.Row="2" SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}">

            <!-- 일별 매출 -->
            <TabItem Header="📅 일별 매출">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="220"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 일별 차트 -->
                    <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,8,0,0">
                        <Grid>
                            <lvc:CartesianChart Series="{Binding DailySeries}"
                                                XAxes="{Binding DailyXAxes}"
                                                AnimationsSpeed="00:00:00.4"/>
                            <!-- 툴팁/호버로 인한 글자 깨짐을 우회하기 위해 마우스 인터랙션을 차단하는 투명 오버레이 -->
                            <Rectangle Fill="Transparent" IsHitTestVisible="True" />
                        </Grid>
                    </Border>

                    <!-- 일별 테이블 -->
                    <Border Grid.Row="2" Style="{StaticResource Card}">
                        <DataGrid ItemsSource="{Binding DailySales}"
                                  VirtualizingPanel.IsVirtualizing="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="날짜"
                                                    Binding="{Binding CreatedAt, StringFormat='yyyy-MM-dd'}"
                                                    Width="160"/>
                                <DataGridTextColumn Header="매출액"
                                                    Binding="{Binding TotalAmount, StringFormat={}{0:N0}}"
                                                    Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- 월별 매출 -->
            <TabItem Header="📆 월별 매출">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="220"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 월별 차트 -->
                    <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,8,0,0">
                        <Grid>
                            <lvc:CartesianChart Series="{Binding MonthlySeries}"
                                                XAxes="{Binding MonthlyXAxes}"
                                                AnimationsSpeed="00:00:00.4"/>
                            <Rectangle Fill="Transparent" IsHitTestVisible="True" />
                        </Grid>
                    </Border>

                    <!-- 월별 테이블 -->
                    <Border Grid.Row="2" Style="{StaticResource Card}">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="연도:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Text="{Binding SelectedYear, UpdateSourceTrigger=PropertyChanged}"
                                         Width="80" Margin="0,0,8,0"/>
                                <Button Content="조회" Style="{StaticResource PrimaryButton}"
                                        Command="{Binding LoadCommand}"/>
                            </StackPanel>
                            <DataGrid DockPanel.Dock="Top" ItemsSource="{Binding MonthlySales}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="연월" Width="160">
                                        <DataGridTextColumn.Binding>
                                            <Binding Path="YM"/>
                                        </DataGridTextColumn.Binding>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="매출액" Width="*">
                                        <DataGridTextColumn.Binding>
                                            <Binding Path="Total" StringFormat="{}{0:N0}"/>
                                        </DataGridTextColumn.Binding>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- 제품별 매출 -->
            <TabItem Header="🏷️ 제품별 매출">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="220"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 제품별 차트 (상위 10개) -->
                    <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,8,0,0">
                        <Grid>
                            <lvc:CartesianChart Series="{Binding ProductSeries}"
                                                XAxes="{Binding ProductXAxes}"
                                                AnimationsSpeed="00:00:00.4"/>
                            <Rectangle Fill="Transparent" IsHitTestVisible="True" />
                        </Grid>
                    </Border>

                    <!-- 제품별 테이블 -->
                    <Border Grid.Row="2" Style="{StaticResource Card}">
                        <DataGrid ItemsSource="{Binding ProductSales}"
                                  VirtualizingPanel.IsVirtualizing="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="바코드"  Binding="{Binding Barcode}"          Width="130"/>
                                <DataGridTextColumn Header="제품명"  Binding="{Binding Name}"             Width="*"/>
                                <DataGridTextColumn Header="판매수량" Binding="{Binding Qty}"              Width="80"/>
                                <DataGridTextColumn Header="매출액"
                                                    Binding="{Binding Total, StringFormat={}{0:N0}}"     Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</UserControl>