<UserControl x:Class="InventoryManager.Views.RevenueView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ 조회 조건 카드 ════════════════════════════════════════ -->
        <Border Grid.Row="0" Style="{StaticResource Card}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="기간:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <DatePicker SelectedDate="{Binding FromDate}" Width="130" Margin="0,0,8,0"/>
                <TextBlock Text="~" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <DatePicker SelectedDate="{Binding ToDate}" Width="130" Margin="0,0,16,0"/>
                <Button Content="🔎 조회"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding LoadCommand}"
                        Margin="0,0,8,0"/>
                <Border Background="{StaticResource ContentBgBrush}"
                        CornerRadius="6" Padding="16,6" Margin="20,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="총 매출: " Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock FontWeight="Bold" Foreground="{StaticResource AccentBrush}">
                            <TextBlock.Text>
                                <Binding Path="TotalRevenue" StringFormat="{}{0:N0} 원"/>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- ═══ 탭 (일별 / 월별 / 제품별) ═══════════════════════════ -->
        <TabControl Grid.Row="2" SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}">

            <!-- 일별 매출 -->
            <TabItem Header="📅 일별 매출">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="220"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,8,0,0">
                        <lvc:CartesianChart Series="{Binding DailySeries}"
                                            XAxes="{Binding DailyXAxes}"
                                            YAxes="{Binding DailyYAxes}"
                                            TooltipPosition="Top"
                                            AnimationsSpeed="00:00:00.4"/>
                    </Border>

                    <Border Grid.Row="2" Style="{StaticResource Card}">
                        <DataGrid ItemsSource="{Binding DailySales}"
                                  VirtualizingPanel.IsVirtualizing="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="날짜"
                                                    Binding="{Binding CreatedAt, StringFormat='yyyy-MM-dd'}"
                                                    Width="160"/>
                                <DataGridTextColumn Header="매출액"
                                                    Binding="{Binding TotalAmount, StringFormat={}{0:N0}}"
                                                    Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- 월별 매출 -->
            <TabItem Header="📆 월별 매출">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="220"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,8,0,0">
                        <lvc:CartesianChart Series="{Binding MonthlySeries}"
                                            XAxes="{Binding MonthlyXAxes}"
                                            YAxes="{Binding MonthlyYAxes}"
                                            TooltipPosition="Top"
                                            AnimationsSpeed="00:00:00.4"/>
                    </Border>

                    <!-- 월별 테이블 (연도/조회 컨트롤 제거 — 상단 기간에서 자동 추출) -->
                    <Border Grid.Row="2" Style="{StaticResource Card}">
                        <DataGrid ItemsSource="{Binding MonthlySales}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="연월" Width="160">
                                    <DataGridTextColumn.Binding>
                                        <Binding Path="YM"/>
                                    </DataGridTextColumn.Binding>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="매출액" Width="*">
                                    <DataGridTextColumn.Binding>
                                        <Binding Path="Total" StringFormat="{}{0:N0}"/>
                                    </DataGridTextColumn.Binding>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- 제품별 매출 -->
            <TabItem Header="🏷️ 제품별 매출">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="220"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,8,0,0">
                        <lvc:CartesianChart Series="{Binding ProductSeries}"
                                            XAxes="{Binding ProductXAxes}"
                                            YAxes="{Binding ProductYAxes}"
                                            TooltipPosition="Top"
                                            AnimationsSpeed="00:00:00.4"/>
                    </Border>

                    <Border Grid.Row="2" Style="{StaticResource Card}">
                        <DataGrid ItemsSource="{Binding ProductSales}"
                                  VirtualizingPanel.IsVirtualizing="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="바코드"  Binding="{Binding Barcode}"          Width="130"/>
                                <DataGridTextColumn Header="제품명"  Binding="{Binding Name}"             Width="*"/>
                                <DataGridTextColumn Header="판매수량" Binding="{Binding Qty}"              Width="80"/>
                                <DataGridTextColumn Header="매출액"
                                                    Binding="{Binding Total, StringFormat={}{0:N0}}"     Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</UserControl>
