<UserControl x:Class="InventoryManager.Views.SaleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="24" PreviewTextInput="Grid_PreviewTextInput" Focusable="True">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ 좌측: 카트 목록 ══════════════════════════════════════ -->
        <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0">
            <DockPanel>

                <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🛒 판매 화면"
                                   Style="{StaticResource SectionTitle}" Margin="0"/>
                        <Button Grid.Column="1" Content="📋 불러오기"
                                Style="{StaticResource GhostButton}"
                                Click="LoadHistory_Click"
                                Margin="0,0,8,0"/>
                        <Button Grid.Column="2" Content="🗑️ 카트 비우기"
                                Style="{StaticResource DangerButton}"
                                Command="{Binding ClearCartCommand}"/>
                    </Grid>
                    <!-- 수정 모드 / 스캔 결과 배너 -->
                    <Border Grid.Row="1" Margin="0,8,0,0" CornerRadius="6" Padding="10,6">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#F0F8FF"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                        <Setter Property="Background" Value="#FFF3CD"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding LastScanResult}"
                                   FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"/>
                    </Border>
                </Grid>

                <DataGrid DockPanel.Dock="Top"
                          ItemsSource="{Binding CartItems}"
                          SelectedItem="{Binding SelectedCartItem}"
                          Height="420" AutoGenerateColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="바코드"  Binding="{Binding Barcode}" Width="130"/>
                        <DataGridTextColumn Header="제품명"  Binding="{Binding Name}"    Width="*"/>
                        <DataGridTextColumn Header="단가"
                                            Binding="{Binding Price, StringFormat={}{0:N0}}"
                                            Width="90"/>
                        <DataGridTemplateColumn Header="수량" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Content="➖" Width="28" Height="28" Margin="0,0,6,0"
                                                Command="{Binding DataContext.DecreaseQtyCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                        <TextBlock Text="{Binding Quantity}" VerticalAlignment="Center"
                                                   Width="36" TextAlignment="Center"/>
                                        <Button Content="➕" Width="28" Height="28" Margin="6,0,0,0"
                                                Command="{Binding DataContext.IncreaseQtyCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="소계"
                                            Binding="{Binding LineTotal, StringFormat={}{0:N0}}"
                                            Width="100"/>
                        <DataGridTemplateColumn Header="" Width="40">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="✕" Width="28" Height="28"
                                            Foreground="{StaticResource DangerBrush}"
                                            Background="Transparent" BorderThickness="0"
                                            Command="{Binding DataContext.RemoveItemCommand,
                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

            </DockPanel>
        </Border>

        <!-- ═══ 우측: 합계 + 결제 ═════════════════════════════════════ -->
        <Border Grid.Column="1" Style="{StaticResource Card}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="결제"
                           Style="{StaticResource SectionTitle}"/>

                <!-- 합계 금액 -->
                <Border DockPanel.Dock="Top"
                        Background="{StaticResource ContentBgBrush}"
                        CornerRadius="8" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="합계 금액" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock FontSize="32" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}"
                                   HorizontalAlignment="Center">
                            <TextBlock.Text>
                                <Binding Path="TotalAmount" StringFormat="{}{0:N0} 원"/>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- 종류 수 -->
                <TextBlock DockPanel.Dock="Top" HorizontalAlignment="Center" Margin="0,0,0,12">
                    <Run Text="총 "/>
                    <Run Text="{Binding CartItemCount, Mode=OneWay}" FontWeight="Bold"/>
                    <Run Text=" 종류"/>
                </TextBlock>

                <!-- ── 수동 바코드 입력 ── -->
                <Border DockPanel.Dock="Top"
                        Background="#F8F9FA" CornerRadius="6"
                        Padding="12" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="바코드 직접 입력" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,6"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="ManualBarcodeBox"
                                     Grid.Column="0"
                                     Text="{Binding ManualBarcode, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,6,0">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Return" Command="{Binding ManualAddCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>
                            <Button Grid.Column="1"
                                    Content="추가"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding ManualAddCommand}"
                                    Padding="10,6"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 결제 버튼 -->
                <Button DockPanel.Dock="Bottom"
                        Style="{StaticResource SuccessButton}"
                        FontSize="18" Height="60"
                        Command="{Binding CheckoutCommand}">
                    <Button.Content>
                        <TextBlock>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="💳 결제 완료"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                            <Setter Property="Text" Value="✏️ 주문 수정 완료"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button.Content>
                </Button>

                <!-- 보류 버튼 -->
                <Button DockPanel.Dock="Bottom"
                        Content="📌 카트 보류"
                        Style="{StaticResource GhostButton}"
                        Command="{Binding HoldCartCommand}"
                        FontSize="14" Height="42"
                        Margin="0,0,0,8"
                        Click="HoldCart_Click"/>

                <!-- 보류 불러오기 버튼 -->
                <Button DockPanel.Dock="Bottom"
                        Content="📂 보류 불러오기"
                        Style="{StaticResource GhostButton}"
                        FontSize="13" Height="36"
                        Margin="0,0,0,6"
                        Click="LoadHold_Click"/>

                <TextBlock DockPanel.Dock="Bottom"
                           Text="{Binding StatusMessage}"
                           FontSize="12" TextWrapping="Wrap"
                           Foreground="{StaticResource AccentBrush}"
                           Margin="0,8" HorizontalAlignment="Center"/>

                <!-- 스캐너 안내 (작게) -->
                <Border DockPanel.Dock="Top"
                        Background="#FFF9C4" CornerRadius="6"
                        Padding="10,6" Margin="0,8,0,0">
                    <TextBlock Text="📡 바코드 스캐너를 이 화면에서 스캔하세요."
                               FontSize="11" TextWrapping="Wrap"
                               Foreground="#7D6608"/>
                </Border>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
