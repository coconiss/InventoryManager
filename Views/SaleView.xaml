<UserControl x:Class="InventoryManager.Views.SaleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 바코드 스캔 입력 캡처: 이 View가 활성화되면 키 입력을 BarcodeService로 전달 -->
    <Grid Margin="24" PreviewTextInput="Grid_PreviewTextInput"
          Focusable="True">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ 좌측: 카트 목록 ══════════════════════════════════════ -->
        <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0">
            <DockPanel>

                <!-- 헤더 + 스캔 상태 -->
                <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="🛒 판매 화면"
                               Style="{StaticResource SectionTitle}" Margin="0"/>
                    <Border Grid.Row="1" Background="#F0F8FF"
                            CornerRadius="6" Padding="10,6">
                        <TextBlock Text="{Binding LastScanResult}"
                                   FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"/>
                    </Border>
                </Grid>

                <!-- 카트 DataGrid -->
                <DataGrid DockPanel.Dock="Top"
                          ItemsSource="{Binding CartItems}"
                          SelectedItem="{Binding SelectedCartItem}"
                          Height="420" AutoGenerateColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="바코드"  Binding="{Binding Barcode}" Width="130"/>
                        <DataGridTextColumn Header="제품명"  Binding="{Binding Name}"    Width="*"/>
                        <DataGridTextColumn Header="단가"
                                            Binding="{Binding Price, StringFormat={}{0:N0}}"
                                            Width="90"/>
                        <DataGridTemplateColumn Header="수량" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Content="➖" Width="28" Height="28" Margin="0,0,6,0"
                                                Command="{Binding DataContext.DecreaseQtyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                        <TextBlock Text="{Binding Quantity}" VerticalAlignment="Center" Width="36" TextAlignment="Center"/>
                                        <Button Content="➕" Width="28" Height="28" Margin="6,0,0,0"
                                                Command="{Binding DataContext.IncreaseQtyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="소계"
                                            Binding="{Binding LineTotal, StringFormat={}{0:N0}}"
                                            Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- 기존 전역 수량 조절 버튼 제거: 각 행의 컨트롤로 대체됨 -->

            </DockPanel>
        </Border>

        <!-- ═══ 우측: 합계 + 결제 ═════════════════════════════════════ -->
        <Border Grid.Column="1" Style="{StaticResource Card}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="결제"
                           Style="{StaticResource SectionTitle}"/>

                <!-- 합계 -->
                <Border DockPanel.Dock="Top"
                        Background="{StaticResource ContentBgBrush}"
                        CornerRadius="8" Padding="16" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="합계 금액" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock FontSize="32" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}"
                                   HorizontalAlignment="Center">
                            <TextBlock.Text>
                                <Binding Path="TotalAmount" StringFormat="{}{0:N0} 원"/>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- 상품 수 -->
                <TextBlock DockPanel.Dock="Top" HorizontalAlignment="Center"
                           Margin="0,0,0,12">
                    <Run Text="총 "/>
                    <Run Text="{Binding CartItemCount, Mode=OneWay}" FontWeight="Bold"/>
                    <Run Text=" 종류"/>
                </TextBlock>

                <!-- 결제 버튼 -->
                <Button DockPanel.Dock="Bottom"
                        Content="💳 결제 완료"
                        Style="{StaticResource SuccessButton}"
                        FontSize="18" Height="60"
                        Command="{Binding CheckoutCommand}"/>

                <TextBlock DockPanel.Dock="Bottom"
                           Text="{Binding StatusMessage}"
                           FontSize="12" TextWrapping="Wrap"
                           Foreground="{StaticResource AccentBrush}"
                           Margin="0,8" HorizontalAlignment="Center"/>

                <!-- 안내 -->
                <Border DockPanel.Dock="Top"
                        Background="#FFF9C4" CornerRadius="6"
                        Padding="12" Margin="0,20,0,0">
                    <TextBlock Text="📡 바코드 스캐너를 이 화면에서 스캔하세요."
                               FontSize="12" TextWrapping="Wrap"
                               Foreground="#7D6608"/>
                </Border>

            </DockPanel>
        </Border>
    </Grid>
</UserControl>
