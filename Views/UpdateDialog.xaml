<!-- Views/UpdateDialog.xaml -->
<Window x:Class="InventoryManager.Views.UpdateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="업데이트 알림" Width="460" Height="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 타이틀 -->
        <TextBlock Grid.Row="0" x:Name="TitleText"
                   FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>

        <!-- 버전 정보 -->
        <TextBlock Grid.Row="1" x:Name="VersionText"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   FontSize="13" Margin="0,0,0,12"/>

        <!-- 릴리즈 노트 -->
        <Border Grid.Row="2" Background="{StaticResource ContentBgBrush}"
                CornerRadius="6" Padding="12" Margin="0,0,0,16">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="ReleaseNotesText"
                           FontSize="12" TextWrapping="Wrap"/>
            </ScrollViewer>
        </Border>

        <!-- 강제 업데이트 경고 -->
        <Border Grid.Row="3" x:Name="MandatoryBanner"
                Background="#FFF3CD" CornerRadius="6"
                Padding="10,6" Margin="0,0,0,12"
                Visibility="Collapsed">
            <TextBlock Text="⚠ 이 버전은 필수 업데이트입니다. 업데이트 후에만 계속 사용할 수 있습니다."
                       FontSize="12" TextWrapping="Wrap" Foreground="#856404"/>
        </Border>

        <!-- 버튼 -->
        <StackPanel Grid.Row="4" Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="SkipButton" Content="나중에"
                    Style="{StaticResource GhostButton}"
                    Width="80" Margin="0,0,8,0"
                    Click="Skip_Click"/>
            <Button x:Name="UpdateButton" Content="지금 업데이트"
                    Style="{StaticResource PrimaryButton}"
                    Click="Update_Click"/>
        </StackPanel>
    </Grid>
</Window>