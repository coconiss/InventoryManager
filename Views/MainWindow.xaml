<Window x:Class="InventoryManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:InventoryManager.ViewModels"
        Title="재고 관리 시스템" Height="780" Width="1200"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>        <!-- 사이드바 -->
            <ColumnDefinition Width="*"/>          <!-- 메인 콘텐츠 -->
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>         <!-- 상태바 -->
        </Grid.RowDefinitions>

        <!-- ══ 사이드바 ══════════════════════════════════════════════════ -->
        <Border Grid.Column="0" Grid.RowSpan="2"
                Background="{StaticResource SidebarBgBrush}">
            <DockPanel>

                <!-- 로고 영역 -->
                <Border DockPanel.Dock="Top" Padding="20,24,20,16"
                        BorderBrush="#2C3E50" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="📦" FontSize="28" HorizontalAlignment="Center"/>
                        <TextBlock Text="재고관리 시스템"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <!-- 메뉴 -->
                <StackPanel DockPanel.Dock="Top" Margin="0,12,0,0">

                    <Button Content="🏷️  제품 관리"
                            Style="{StaticResource MenuButton}"
                            Command="{Binding NavigateProductCommand}"/>

                    <Button Content="📦  재고 관리"
                            Style="{StaticResource MenuButton}"
                            Command="{Binding NavigateStockCommand}"/>

                    <Button Content="🛒  판매"
                            Style="{StaticResource MenuButton}"
                            Command="{Binding NavigateSaleCommand}"/>

                    <Button Content="📊  매출 관리"
                            Style="{StaticResource MenuButton}"
                            Command="{Binding NavigateRevenueCommand}"/>

                    <Button Content="⚙️  설정"
                            Style="{StaticResource MenuButton}"
                            Command="{Binding NavigateSettingsCommand}"/>
                </StackPanel>

                <!-- 하단 버전 -->
                <Border DockPanel.Dock="Bottom" Padding="20,12">
                    <TextBlock Text="{Binding AppVersion}"
                               FontSize="11" Foreground="#636E72"
                               HorizontalAlignment="Center"/>
                </Border>

            </DockPanel>
        </Border>

        <!-- ══ 메인 콘텐츠 ════════════════════════════════════════════════ -->
        <ContentControl Grid.Column="1" Grid.Row="0"
                        Content="{Binding CurrentView}"
                        Background="{StaticResource ContentBgBrush}"/>

        <!-- ══ 상태바 ══════════════════════════════════════════════════ -->
        <Border Grid.Column="1" Grid.Row="1"
                Style="{StaticResource StatusBar}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding ContactInfo}"
                           Foreground="#95A5A6" FontSize="11"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding AppVersion}"
                           Foreground="#95A5A6" FontSize="11"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
