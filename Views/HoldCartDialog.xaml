<Window x:Class="InventoryManager.Views.HoldCartDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="보류 카트 목록"
        Height="480" Width="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="180"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 보류 카트 목록 -->
        <Border Grid.Row="0" Style="{StaticResource Card}">
            <DockPanel>
                <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="📌 보류된 카트"
                               Style="{StaticResource SectionTitle}" Margin="0"/>
                    <Button x:Name="DeleteHoldButton"
                            Grid.Column="1"
                            Content="🗑️ 선택 삭제"
                            Style="{StaticResource DangerButton}"
                            IsEnabled="False"
                            Click="DeleteHold_Click"/>
                </Grid>
                <DataGrid x:Name="HoldGrid"
                          DockPanel.Dock="Top"
                          AutoGenerateColumns="False"
                          SelectionMode="Single"
                          SelectionChanged="HoldGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="번호"   Binding="{Binding Id}"          Width="60"/>
                        <DataGridTextColumn Header="내용"   Binding="{Binding Label}"        Width="*"/>
                        <DataGridTextColumn Header="항목수" Binding="{Binding ItemCount}"    Width="70"/>
                        <DataGridTextColumn Header="합계금액"
                                            Binding="{Binding TotalAmount, StringFormat={}{0:N0}}"
                                            Width="110"/>
                        <DataGridTextColumn Header="보류시각"
                                            Binding="{Binding CreatedAt, StringFormat='MM/dd HH:mm'}"
                                            Width="110"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

        <!-- 선택 카트 상세 -->
        <Border Grid.Row="2" Style="{StaticResource Card}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="선택 카트 상세"
                           Style="{StaticResource SectionTitle}"/>
                <DataGrid x:Name="DetailGrid"
                          DockPanel.Dock="Top"
                          AutoGenerateColumns="False"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="바코드"  Binding="{Binding Barcode}"      Width="130"/>
                        <DataGridTextColumn Header="제품명"  Binding="{Binding ProductName}"  Width="*"/>
                        <DataGridTextColumn Header="수량"    Binding="{Binding Quantity}"     Width="70"/>
                        <DataGridTextColumn Header="단가"
                                            Binding="{Binding Price, StringFormat={}{0:N0}}"  Width="90"/>
                        <DataGridTextColumn Header="소계"
                                            Binding="{Binding LineTotal, StringFormat={}{0:N0}}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

        <!-- 버튼 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="취소" Style="{StaticResource GhostButton}"
                    Width="80" Margin="0,0,8,0"
                    Click="Cancel_Click"/>
            <Button x:Name="LoadButton"
                    Content="📋 이 카트 불러오기"
                    Style="{StaticResource PrimaryButton}"
                    IsEnabled="False"
                    Click="Load_Click"/>
        </StackPanel>
    </Grid>
</Window>
