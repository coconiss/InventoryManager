<Window x:Class="InventoryManager.Views.SaleHistoryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="과거 판매 내역"
        Height="640" Width="820"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="200"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 검색 조건 -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="기간:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <DatePicker x:Name="FromDatePicker" Width="130" Margin="0,0,8,0"/>
                <TextBlock Text="~" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <DatePicker x:Name="ToDatePicker" Width="130" Margin="0,0,12,0"/>
                <Button Content="🔍 조회" Style="{StaticResource PrimaryButton}"
                        Click="Search_Click"/>
            </StackPanel>
        </Border>

        <!-- 판매 목록 -->
        <Border Grid.Row="1" Style="{StaticResource Card}">
            <DockPanel>
                <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="판매 목록"
                               Style="{StaticResource SectionTitle}" Margin="0"/>
                    <!-- 판매 삭제 버튼 -->
                    <Button x:Name="DeleteSaleButton"
                            Grid.Column="1"
                            Content="🗑️ 선택 주문 삭제"
                            Style="{StaticResource DangerButton}"
                            IsEnabled="False"
                            Click="DeleteSale_Click"/>
                </Grid>
                <DataGrid x:Name="SaleGrid"
                          DockPanel.Dock="Top"
                          SelectionChanged="SaleGrid_SelectionChanged"
                          AutoGenerateColumns="False"
                          SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="주문번호"
                                            Binding="{Binding Id}" Width="80"/>
                        <DataGridTextColumn Header="판매일시"
                                            Binding="{Binding CreatedAt, StringFormat='yyyy-MM-dd HH:mm'}"
                                            Width="160"/>
                        <DataGridTextColumn Header="합계금액"
                                            Binding="{Binding TotalAmount, StringFormat={}{0:N0}}"
                                            Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

        <!-- 선택 주문 상세 -->
        <Border Grid.Row="3" Style="{StaticResource Card}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="선택 주문 상세"
                           Style="{StaticResource SectionTitle}"/>
                <DataGrid x:Name="DetailGrid"
                          DockPanel.Dock="Top"
                          AutoGenerateColumns="False"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="바코드"    Binding="{Binding Barcode}"      Width="130"/>
                        <DataGridTextColumn Header="제품명"    Binding="{Binding ProductName}"  Width="*"/>
                        <DataGridTextColumn Header="수량"      Binding="{Binding Quantity}"     Width="70"/>
                        <DataGridTextColumn Header="단가"
                                            Binding="{Binding Price, StringFormat={}{0:N0}}"   Width="90"/>
                        <DataGridTextColumn Header="소계"
                                            Binding="{Binding LineTotal, StringFormat={}{0:N0}}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

        <!-- 버튼 -->
        <StackPanel Grid.Row="4" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="취소" Style="{StaticResource GhostButton}"
                    Width="80" Margin="0,0,8,0"
                    Click="Cancel_Click"/>
            <Button x:Name="LoadButton"
                    Content="📋 이 주문 불러오기 (수정)"
                    Style="{StaticResource PrimaryButton}"
                    IsEnabled="False"
                    Click="Load_Click"/>
        </StackPanel>
    </Grid>
</Window>