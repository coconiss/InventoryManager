<UserControl x:Class="InventoryManager.Views.StockView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:InventoryManager.Helpers">

    <UserControl.Resources>
        <helpers:StockColorConverter x:Key="StockColorConverter"/>
        <!-- StockStatusConverter was missing; provide a simple TextConverter fallback -->
        <helpers:StockStatusConverter x:Key="StockStatusConverter"/>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="260"/>
        </Grid.RowDefinitions>

        <!-- ═══ 상단: 재고 목록 ══════════════════════════════════════ -->
        <Border Grid.Row="0" Style="{StaticResource Card}">
            <DockPanel>
                <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="📦 재고 현황"
                               Style="{StaticResource SectionTitle}" Margin="0"/>
                    <TextBlock Grid.Column="1" Text="조정수량:"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox Grid.Column="2"
                             Text="{Binding AdjustQuantity, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,6,0"/>
                    <TextBox Grid.Column="3"
                             Text="{Binding AdjustRemark, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,6,0">
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                <Setter Property="ToolTip" Value="비고 입력"/>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    <Button Grid.Column="5" Content="재고 조정"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding AdjustCommand}"/>
                </Grid>

                <TextBlock DockPanel.Dock="Top"
                           Text="{Binding StatusMessage}"
                           Foreground="{StaticResource AccentBrush}"
                           FontSize="12" Margin="0,0,0,8"/>

                <DataGrid DockPanel.Dock="Top"
                          ItemsSource="{Binding Products}"
                          SelectedItem="{Binding SelectedProduct}"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="바코드" Binding="{Binding Barcode}" Width="140"/>
                        <DataGridTextColumn Header="제품명" Binding="{Binding Name}"    Width="*"/>
                        <DataGridTemplateColumn Header="현재재고" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding CurrentQuantity,
                                                Converter={StaticResource StockColorConverter}}"
                                            CornerRadius="4" Padding="6,2">
                                        <TextBlock Text="{Binding CurrentQuantity}"
                                                   HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="상태"
                                            Binding="{Binding CurrentQuantity,
                                                Converter={StaticResource StockStatusConverter}}"
                                            Width="80"/>
                        <DataGridTextColumn Header="입고단가"
                                            Binding="{Binding CostPrice, StringFormat={}{0:N0}}"
                                            Width="90"/>
                        <DataGridTextColumn Header="판매단가"
                                            Binding="{Binding SalePrice, StringFormat={}{0:N0}}"
                                            Width="90"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

        <!-- ═══ 하단: 재고 이력 ══════════════════════════════════════ -->
        <Border Grid.Row="2" Style="{StaticResource Card}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Style="{StaticResource SectionTitle}">
                    <Run Text="📋 이력 - "/>
                    <Run Text="{Binding SelectedProduct.Name}"/>
                </TextBlock>
                <DataGrid DockPanel.Dock="Top"
                          ItemsSource="{Binding History}"
                          VirtualizingPanel.IsVirtualizing="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="일시"     Binding="{Binding CreatedAt, StringFormat='yyyy-MM-dd HH:mm'}" Width="140"/>
                        <DataGridTextColumn Header="구분"     Binding="{Binding Type}"                Width="70"/>
                        <DataGridTextColumn Header="수량"     Binding="{Binding Quantity}"            Width="70"/>
                        <DataGridTextColumn Header="변경 전"  Binding="{Binding QuantityBefore}"      Width="70"/>
                        <DataGridTextColumn Header="변경 후"  Binding="{Binding QuantityAfter}"       Width="70"/>
                        <DataGridTextColumn Header="비고"     Binding="{Binding Remark}"              Width="*"/>
                        <DataGridTextColumn Header="처리자"   Binding="{Binding CreatedBy}"           Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
