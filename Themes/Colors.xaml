<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── 브랜드 색상 ── -->
    <Color x:Key="PrimaryColor">#2C3E50</Color>
    <Color x:Key="PrimaryLightColor">#34495E</Color>
    <Color x:Key="AccentColor">#3498DB</Color>
    <Color x:Key="AccentHoverColor">#2980B9</Color>
    <Color x:Key="SuccessColor">#27AE60</Color>
    <Color x:Key="WarningColor">#F39C12</Color>
    <Color x:Key="DangerColor">#E74C3C</Color>
    <Color x:Key="SidebarBg">#1A252F</Color>
    <Color x:Key="ContentBg">#F5F6FA</Color>
    <Color x:Key="CardBg">#FFFFFF</Color>
    <Color x:Key="BorderColor">#DFE6E9</Color>
    <Color x:Key="TextPrimary">#2D3436</Color>
    <Color x:Key="TextSecondary">#636E72</Color>
    <Color x:Key="TextLight">#FFFFFF</Color>

    <!-- ── Brush 변환 ── -->
    <SolidColorBrush x:Key="PrimaryBrush"       Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryLightBrush"  Color="{StaticResource PrimaryLightColor}"/>
    <SolidColorBrush x:Key="AccentBrush"        Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush"   Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="SuccessBrush"       Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush"       Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="DangerBrush"        Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="SidebarBgBrush"     Color="{StaticResource SidebarBg}"/>
    <SolidColorBrush x:Key="ContentBgBrush"     Color="{StaticResource ContentBg}"/>
    <SolidColorBrush x:Key="CardBgBrush"        Color="{StaticResource CardBg}"/>
    <SolidColorBrush x:Key="BorderBrush"        Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush"   Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
    <SolidColorBrush x:Key="TextLightBrush"     Color="{StaticResource TextLight}"/>

    <!-- ── 재고 상태 색상 ── -->
    <SolidColorBrush x:Key="StockZeroBrush"   Color="#FFCCCC"/>
    <SolidColorBrush x:Key="StockLowBrush"    Color="#FFF9C4"/>
    <SolidColorBrush x:Key="StockNormalBrush" Color="Transparent"/>

</ResourceDictionary>
